# NG Scanner — пример переменных окружения.
# Скопируйте в .env (он игнорируется git) для локальных скриптов и экспериментов.
#
# В самом приложении ключи вводятся в UI и хранятся в EncryptedSharedPreferences —
# в APK они не зашиваются.

# Anthropic Claude API — https://console.anthropic.com
ANTHROPIC_API_KEY=

# Cloud.ru Evolution Foundation Models (OpenAI-совместимый API)
# https://foundation-models.api.cloud.ru/v1
CLOUDRU_API_KEY=
